# Forum Operating System — env vars
# Copy to .env and adjust before running `docker compose up`.

# Database (defaults sirven para dev local; para prod usá credenciales fuertes)
DATABASE_URL=postgresql://forum:forum@db:5432/forum
POSTGRES_USER=forum
POSTGRES_PASSWORD=forum
POSTGRES_DB=forum

# Puerto en el host donde expone la app
APP_PORT=8000

# Admin (/admin requiere HTTP Basic Auth)
# Usuario: cualquier string. Password: el que pongas acá.
ADMIN_PASSWORD=change-me-before-deploy
